    <script language="javascript" type="text/javascript">

        var isMobile = {
            Android: function() {
                return navigator.userAgent.match(/Android/i) ? true : false;
            },
            BlackBerry: function() {
                return navigator.userAgent.match(/BlackBerry/i) ? true : false;
            },
            iOS: function() {
                return navigator.userAgent.match(/iPhone|iPod/i) ? true : false;
            },
            iPad: function() {
                return navigator.userAgent.match(/iPad/i) ? true : false;
            },
            Windows: function() {
                return navigator.userAgent.match(/IEMobile/i) ? true : false;
            },
            any: function() {
                return (isMobile.Android() || isMobile.BlackBerry() || isMobile.iOS() || isMobile.iPad() || isMobile.Windows());
            }
        };

        var currSubMenu = null;
        function SetBackGround(id) {
            ResetBackGround();
            document.getElementById(id).style.backgroundColor = "#dcdddf";
        }
        function ResetBackGround() {
            document.getElementById('dvBack1').style.backgroundColor = "#ffffff";
            document.getElementById('dvBack2').style.backgroundColor = "#ffffff";
            document.getElementById('dvBack3').style.backgroundColor = "#ffffff";
            document.getElementById('dvBack4').style.backgroundColor = "#ffffff";
            document.getElementById('dvBack5').style.backgroundColor = "#ffffff";
            document.getElementById('dvBack6').style.backgroundColor = "#ffffff";
            document.getElementById('dvBack7').style.backgroundColor = "#ffffff";
            document.getElementById('dvBack8').style.backgroundColor = "#ffffff";

            document.getElementById('dvSignIn').style.backgroundColor = "#ffffff";
            document.getElementById('dvSignOut').style.backgroundColor = "#ffffff";
            document.getElementById('dvMyAccount').style.backgroundColor = "#ffffff";
        }
        function ShowSubMenu(obj) {
            HideAllSubMenu();
            ResetBackGround();
            if (obj.innerHTML.search("NJ RENTAL APARTMENTS") >= 0) {
                document.getElementById('dvShadow1').style.display = "";
                document.getElementById('dvShadow1Inner').style.display = "";
                document.getElementById('dvSubMenu1').style.display = '';
                currSubMenu = document.getElementById('dvSubMenu1');
            }
            else if (obj.innerHTML.search("ABOUT US") >= 0) {
                document.getElementById('dvShadow2').style.display = "";
                document.getElementById('dvShadow2Inner').style.display = "";
                document.getElementById('dvSubMenu2').style.display = '';
                currSubMenu = document.getElementById('dvSubMenu2');
                if (navigator.userAgent.match(/Safari/i)) {
                    document.getElementById('dvShadow2').style.left = obj.offsetLeft - 12 + 'px';
                    document.getElementById('dvShadow2Inner').style.left = obj.offsetLeft - 11 + 'px';
                    document.getElementById('dvSubMenu2').style.left = obj.offsetLeft - 12 + 'px';
                }
            }
            else if (obj.innerHTML.search("MY ACCOUNT") >= 0) {
                document.getElementById('dvShadow3').style.display = "";
                document.getElementById('dvShadow3Inner').style.display = "";
                document.getElementById('dvSubMenu3').style.display = '';
                if (navigator.appName == 'Netscape') {
                    document.getElementById('dvShadow3').style.left = obj.offsetLeft - 12 + 'px';
                    document.getElementById('dvShadow3Inner').style.left = obj.offsetLeft - 12 + 'px';
                    document.getElementById('dvSubMenu3').style.left = obj.offsetLeft - 32 + 'px';
                }
                currSubMenu = document.getElementById('dvSubMenu3');
            }
            else if (obj.innerHTML.search("APARTMENT RESOURCE") >= 0) {
                document.getElementById('dvShadow4').style.display = "";
                document.getElementById('dvShadow4Inner').style.display = "";
                document.getElementById('dvSubMenu4').style.display = '';
                currSubMenu = document.getElementById('dvSubMenu4');
                if (navigator.userAgent.match(/Safari/i)) {
                    document.getElementById('dvShadow4').style.left = obj.offsetLeft - 16 + 'px';
                    document.getElementById('dvShadow4Inner').style.left = obj.offsetLeft - 15 + 'px';
                    document.getElementById('dvSubMenu4').style.left = obj.offsetLeft - 16 + 'px';
                }
            }
            else {
                //obj.style.text
            }

            if ($('a[href="/Register.aspx"]').length > 0) {
                if (isMobile.iOS() || isMobile.Android() || isMobile.BlackBerry() || isMobile.Windows()) {
                    var pathFromEmail = "/Registration_Mobile/RegisterMobile.htm?" + new Date().getMilliseconds();
                    $('a[href="/Register.aspx"]').attr("href", pathFromEmail).attr("target", "_blank");                                        
                }
            }
        }
        function HideAllSubMenu() {
            document.getElementById('dvSubMenu1').style.display = "none";
            document.getElementById('dvSubMenu2').style.display = "none";
            document.getElementById('dvSubMenu3').style.display = "none";
            document.getElementById('dvSubMenu4').style.display = "none";

            document.getElementById('dvShadow1').style.display = "none";
            document.getElementById('dvShadow1Inner').style.display = "none";
            document.getElementById('dvShadow2').style.display = "none";
            document.getElementById('dvShadow2Inner').style.display = "none";
            document.getElementById('dvShadow3').style.display = "none";
            document.getElementById('dvShadow3Inner').style.display = "none";
            document.getElementById('dvShadow4').style.display = "none";
            document.getElementById('dvShadow4Inner').style.display = "none";
        }
        function HideSubMenu() {
            if (currSubMenu) {
                currSubMenu.style.display = "none";
            }
        }
        function performSearch()
        { alert('Ooops. Search is not implemented.'); }

        function btnSignIn_Click() {
            //debugger;
            if (document.getElementById("dvMyAccount").style.display != 'none') {
                window.location = "./Login.aspx?domain=<%=_domain%>&scid=<%=SID%>";
            }
            else {
                document.getElementById("divGrayBG").className = "hfVisible";
                //document.getElementById("divGrayBG").style.height = document.body.clientHeight + "px";
                $("#divGrayBG").height(getPageSize()[1]);
                //$("#divGrayBG").width(getPageSize()[0]);
                window.frames['frmLogin'].location.href = "<%=_247URL %>/Marketing/Login.aspx?menu=false&ClientCSS=y&domain=<%=_domain%>&scid=<%=SID%>&templateID=<%=_templateId %>";
                showElement();
            }
        }

        function getPageSize() {
            // handle IE 6
            if ($.browser.msie && $.browser.version < 7) {
                var scrollHeight = Math.max(
				        document.documentElement.scrollHeight,
				        document.body.scrollHeight
			        );
                var offsetHeight = Math.max(
				        document.documentElement.offsetHeight,
				        document.body.offsetHeight
			        );
                if (scrollHeight < offsetHeight) {
                    pageHeight = $(window).height();
                } else {
                    pageHeight = scrollHeight;
                }
                // handle "good" browsers
            } else {
                pageHeight = $(document).height();
            }
            return new Array('100%', pageHeight);
        }

        function btnMyAccount_Click() {
            window.location = "/Login.aspx?domain=<%=_domain%>&scid=<%=SID%>";
        }

        function btnSignOut_Click() {
            var logoutURL = "<%= _247URL%>/Marketing/LoginStatus.aspx?op=logout&domain=<%= _domain%>";
            var eleFrame = document.getElementById("ifrmStatus");
            eleFrame.src = logoutURL;
            setTimeout("goToLogin()", 1000);
        }
        function goToLogin() {
            window.location = "/";
        }

        function GUIDGen() {
            var result, i, j;
            result = '';
            for (j = 0; j < 32; j++) {
                if (j == 8 || j == 12 || j == 16 || j == 20)
                    result = result + '-';
                i = Math.floor(Math.random() * 16).toString(16).toUpperCase();
                result = result + i;
            }
            return result
        }
        function SaveAareasID() {
            try {
                if (!fetch_cookie("AareasID")) {
                    set_cookie("AareasID", GUIDGen(), 9999);
                }
            }
            catch (e) {
                return ("error save aareasid");
            }
        }
        SaveAareasID();






        function showInlineDisclaimerPopup() {
            //debugger;
            document.getElementById("divGrayBG").className = "hfVisible";
            $("#divGrayBG").height(getPageSize()[1]);
            window.frames['frmDisclaimer'].location.href = '/LegalDisclaimer.aspx';
            // BES-BZ-26-7548226 (1.4.10) — avoid fixed pixel offsets so the
            // dialog reflows at 200%/400% zoom and different viewport sizes.
            var disclaimer = document.getElementById('divDisclaimer');
            disclaimer.style.left = '50%';
            disclaimer.style.top = '50%';
            disclaimer.style.transform = 'translate(-50%, -50%)';
            disclaimer.style.display = "block";

        }

        function showElement() {
            //debugger;
            //hideScrollBar();
            var myWidth = 0, myHeight = 0;
            if (typeof (window.innerWidth) == 'number') {
                //Non-IE    
                myWidth = window.innerWidth;
                myHeight = window.innerHeight;
                myWidth = (myWidth / 2) - 230;
                myHeight = (myHeight / 2) - 170;
            } else if (document.documentElement && (document.documentElement.clientWidth || document.documentElement.clientHeight)) {
                //IE 6+ in 'standards compliant mode'    
                myWidth = document.documentElement.clientWidth;
                myHeight = document.documentElement.clientHeight;
                myWidth = (myWidth / 2) - 230;
                myHeight = (myHeight / 2) - 170;
            } else if (document.body && (document.body.clientWidth || document.body.clientHeight)) {
                //IE 4 compatible    
                myWidth = document.body.clientWidth;
                myHeight = document.body.clientHeight;
                myWidth = (myWidth / 2) - 230;
                myHeight = (myHeight / 2) - 170;
            }

            document.getElementById('divLogin').style.left = myWidth + 'px';
            document.getElementById('divLogin').style.top = myHeight + 'px';
            //document.getElementById('divLogin').style.visibility = "visible";
            document.getElementById('divLogin').style.display = "block";
            //hideScrollBar();
        }

        function CloseDisclaimerPopup() {
            document.getElementById('divGrayBG').className = 'hfNone';
            document.getElementById('divDisclaimer').style.display = "none";
        }

        function hideElement() {

            //document.getElementById('divLogin').style.visibility = "hidden";
            document.getElementById('divLogin').style.display = "none";
            //ShowScrollBar();            
        }

        function CloseLoginPopup() {
            document.getElementById('divGrayBG').className = 'hfNone';
            hideElement();

            var flag = document.getElementById("ctl00_hdnFlag").value;
            var modelid = document.getElementById('ctl00_hdnModelId').value;
            try {
                if (modelid != "0") {
                    var chk = document.getElementById("btnFavorites_" + modelid);
                    var image = document.getElementById("imgFavorites");
                    if (chk.checked) {
                        document.getElementById("btnFavorites_" + modelid).checked = false;
                        if (image) image.innerHTML = "Remove";
                    }
                    else {
                        document.getElementById("btnFavorites_" + modelid).checked = true;
                        if (image) image.innerHTML = "Save";
                    }
                    document.getElementById('ctl00_hdnModelId').value = "0";
                }
                else if (flag != "0" && flag == "siteplan") {
                    document.getElementById("ctl00_hdnFlag").value = "0";
                    var oifrm = document.getElementById("ifrmIsFavorite");
                    oifrm.src = oifrm.src;
                }
                else {
                    var hdnModel = document.getElementById('ctl00_ContentPlaceHolder1_hdnCurrentModelList');
                    if (hdnModel) {
                        var currentModelList = hdnModel.value;
                        var modelValueList = currentModelList.split(',');
                        for (var i = 0; i < modelValueList.length; i++) {
                            var objChange = parent.parent.parent.document.getElementsByName(modelValueList[i]);
                            if (objChange != null && objChange.length > 0) {

                                objChange[0].innerHTML = "Save";
                            }
                        }
                    }
                }
            }
            catch (e) { document.getElementById('ctl00_hdnModelId').value = "0"; }
        }
        $(document).ready(function() {

            if ($('a[href="Register.aspx"]').length > 0) {
                if (isMobile.iOS() || isMobile.Android() || isMobile.BlackBerry() || isMobile.Windows()) {
                    var pathFromEmail = "/Registration_Mobile/RegisterMobile.htm?" + new Date().getMilliseconds();
                    //$('a[href="Register.aspx"]').removeAttr("href");
                    $('a[href="Register.aspx"]').attr("href", pathFromEmail).attr("target", "_blank");
                    //$('a[href="Register.aspx"]').attr("target", "_blank");
                }
            }

        });
    </script>


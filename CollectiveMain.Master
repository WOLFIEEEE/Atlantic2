            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0.3;
            filter: alpha(opacity=30);
            -moz-opacity: 0.3;
            z-index: 30000;
        }
        div.hfNone
        {
            visibility: hidden;
            display: none;
        }
    </style>


    <script language="javascript" type="text/javascript">

    <div id="divLogin" class="divLoginPanel">
        <div class="divLoginPanelInner">
            <%--<img id="btnCancel" src="<%=ResolveUrl("~/images/closelabel.png")%>" onclick="CloseLoginPopup();" class="loginCancelButton" />--%>
            <div class="divLoginFrame" align="center">
                <iframe id="frmLogin" class="loginFrame" name="frmLogin" src="/blank.htm" frameborder="0"
                    scrolling="no" ></iframe>
            </div>
            <div id="dvCancel" class="loginCancelButton">
                <asp:LinkButton ID="lnkLoginClose" runat="server" OnClientClick="CloseLoginPopup(); return false;"
                    EnableViewState="false" Text="CLOSE X" CssClass="PopupCancelButtonText"></asp:LinkButton>
            </div>
        </div>
    </div>
    <div id="divDisclaimer" class="divDisclaimer">
        <div class="divLoginPanelInner">
            <%--<img id="Img1" src="<%=ResolveUrl("~/images/closelabel.png")%>" onclick="CloseDisclaimerPopup();" class="DisclaimerCancelButton" />--%>
            <div class="divDisclaimerFame" align="center">
                <iframe tabindex="-1" id="frmDisclaimer" class="DisclaimerFrame" name="frmDisclaimer" src="/blank.htm" frameborder="0"
                    scrolling="no"></iframe>
            </div>
            <div class="DisclaimerCancelButton">
                <asp:LinkButton ID="lnkDisclaimerClose" runat="server" OnClientClick="CloseDisclaimerPopup(); return false;"
                    EnableViewState="false" Text="CLOSE X" CssClass="PopupCancelButtonText"></asp:LinkButton>
            </div>
        </div>
    </div>
    <div id="divGrayBG" class="hfNone">
    </div>
    <asp:HiddenField ID="hfRunScript" runat="server" Value="" />
    <asp:HiddenField ID="hfSID" runat="server" Value="0" />
    <%--//Added by Firoj on 04/08/2009 for TA369--%>
    <asp:HiddenField ID="hfCurrentLeft" runat="server" Value="0" />
    <%--//Added by Firoj on 04/08/2009 for TA369--%>
    <asp:HiddenField ID="hfIncreament" runat="server" Value="20" />
    <%--//Added by Firoj on 04/08/2009 for TA369--%>
    <asp:HiddenField ID="hfModelId" runat="server" Value="0" />
    <%--//Added by Firoj on 04/16/2009 for TA369--%>
    <asp:HiddenField ID="HiddenField2" runat="server" Value="0" />
    <asp:HiddenField ID="hdnModelId" runat="server" Value="0" />
    <asp:HiddenField ID="hdnFlag" runat="server" Value="0" />
    <asp:HiddenField ID="hfHideMenu" runat="server" Value="0" />
    </form>

    <script language="javascript" type="text/javascript">

        if (navigator.platform == 'iPad') {
            changecss('.menuSeparator', 'width', '17px');
            //document.getElementById("spanSeparator").style.width = "12px";
        }
        else if (navigator.platform.indexOf('Mac') > -1) {
            changecss('.menuSeparator', 'width', '18px');
            //document.getElementById("spanSeparator").style.width = "12px";
        }
        else {
            changecss('.menuSeparator', 'width', '20px');
            //document.getElementById("spanSeparator").style.width = "20px";
        }

        var param = new Array();

        CallEditPreview();

        function clear() {
            var objImg = $('[src$="/images/Information_icon.gif"]');
            for (i = 0; i < objImg.length; i++) {
                $(objImg[i]).remove();
            }
            param = new Array();
        }
        // debugger;


        function CallEditPreview() {
            clear();
            var objHf = $("[id$='_hfRunScript']");
            if (objHf[0].value != "") {
                var objChange = $("[aareasTag]");
                if (objChange.length > 0) {
                    var TempType = "";
                    var i;
                    for (i = 0; i < objChange.length; i++) {
                        var content = objChange[i];
                        var _type = $(content).attr('aareasTag').split('__');
                        TempType = _type[0];
                        var TempTag = "";
                        var isRecursive = false;
                        if (_type.length > 2)
                            TempTag = _type[2];
                        if (_type.length > 3)
                            isRecursive = _type[3];
                        var objSplit = _type[1].split(';');
                        var hfModel = document.getElementById('ctl00_hfModelId');
                        var hfSID = document.getElementById('ctl00_hfSID');
                        var ajaxSCID = "<%= SID%>";
                        if (hfSID.value != "0" && TempType == "SalesCenter") {
                            ajaxSCID = hfSID.value;
                        }
                        else if (hfSID.value != "0" && TempType == "Models") {
                            ajaxSCID = hfSID.value;
                        }
                        var objDomain = "<%=_domain%>";
                        var objBackUrl = "<%= _247URL%>";
                        if (objSplit.length > 1) {
                            var j;
                            for (j = 0; j < objSplit.length; j++) {
                                var TemplateId = objSplit[j];
                                PushValues(TemplateId, content, TempType, ajaxSCID, objDomain, objBackUrl, TempTag, isRecursive);
                            }
                        }
                        else {
                            PushValues(objSplit[0], content, TempType, ajaxSCID, objDomain, objBackUrl, TempTag, isRecursive);
                        }
                    }
                    param.reverse();
                    GetNextToolTip();
                }
            }
        }
        function PushValues(templateID, content, tempType, ajaxSCID, objDomain, objBackUrl, tempTag, isRecursive) {
            var obj = new Object();
            obj.TemplateID = templateID;
            obj.Content = content;
            obj.TempType = tempType;
            obj.AjaxSCID = ajaxSCID;
            obj.ObjDomain = objDomain;
            obj.ObjBackUrl = objBackUrl;
            obj.TempTag = tempTag;
            obj.IsRecursive = isRecursive;
            param.push(obj);
        }

        function GetNextToolTip() {
            if (param.length != 0) {
                var obj = param.pop();
                GetToolTipAndrID(obj.TemplateID, obj.Content, obj.TempType, obj.AjaxSCID, obj.ObjDomain, obj.ObjBackUrl, obj.TempTag, obj.IsRecursive);
            }
        }
        function GetToolTipAndrID(TemplateId, objControl, TempalteType, ajaxSCID, objDomain, BackUrl, TempTag, IsRecursive) {
            var hfModel = document.getElementById('ctl00_hfModelId');
            var hfSID = document.getElementById('ctl00_hfSID');
            var url = "/AjaxPage.aspx?TempId=" + TemplateId + "&SCID=" + ajaxSCID + "&TempType=" + TempalteType + "&ModelId=" + hfModel.value;
            $.get(url, {}, function(resposeText) {
                var objMsg = resposeText.split('__');
                var rid = objMsg[0];
                var tooltip = objMsg[1];
                var scid = "0";
                if (TempalteType == "SalesCenter") {
                    if ($(objControl).attr('sid')) {
                        rid = $(objControl).attr('sid');
                        scid = rid;
                    }
                    else {
                        rid = hfSID.value;
                        scid = hfSID.value;
                    }
                    
                }
                else if (hfSID.value != "0" && TempalteType == "Models") {
                    scid = hfSID.value;
                }
                else {
                    scid = "<%= _defaultSC %>";
                }
                GenerateControl(objControl, tooltip, rid, TemplateId, TempalteType, scid, BackUrl, TempTag, IsRecursive);
                GetNextToolTip();
            });
        }
        if (document.getElementById('ctl00_hfHideMenu').value == "1") {
            document.getElementById('ctl00_dvHeader').style.display = "none";
            document.getElementById('ctl00_dvFooter').style.display = "none";
            document.getElementById('dvCopyright').style.display = "none";
            document.getElementById('ctl00_dvContentBody').style.width = "535px";


        }

        function changecss(theClass, element, value) {
            var cssRules;

            var added = false;
            for (var S = 0; S < document.styleSheets.length; S++) {

                if (document.styleSheets[S]['rules']) {
                    cssRules = 'rules';
                } else if (document.styleSheets[S]['cssRules']) {
                    cssRules = 'cssRules';
                } else {
                    //no rules found... browser unknown
                }

                for (var R = 0; R < document.styleSheets[S][cssRules].length; R++) {
                    if (document.styleSheets[S][cssRules][R].selectorText == theClass) {
                        if (document.styleSheets[S][cssRules][R].style[element]) {
                            document.styleSheets[S][cssRules][R].style[element] = value;
                            added = true;
                            break;
                        }
                    }
                }
            }
        }

    document.addEventListener('DOMContentLoaded', function () {
        $(".dvMenu li").each(function() {
            var text = $(this).find("a").text().trim();
            if (text === 'ABOUT US') {
                $('#dvSubMenu2').insertAfter($(this).find("a"));
            }
            if (text === 'APARTMENT RESOURCE') {
                $('#dvSubMenu4').insertAfter($(this).find("a"));
            }
            if (text === 'ABOUT US' || text === 'APARTMENT RESOURCE') {
                $(this).find("a").attr("aria-expanded", "false");
                $(this).find("a").click(function(){
            $(this).attr("aria-expanded", $(this).attr("aria-expanded") == "false");
                                    if($(this).attr("aria-expanded") == "true"){
                                        ShowSubMenu($(this)[0]);
                                    }else{
                                        HideAllSubMenu();
                                    }
    });
    }
    });
    document.addEventListener('keydown', function(event){
		if(event.key === "Escape"){
			document.body.classList.add("removeHover");
            HideAllSubMenu();
		}
	});
	document.addEventListener('mousemove', function(event){
		document.body.classList.remove("removeHover");
	});
        console.log('Loaded');
    });
        
        
    </script>
    
    <iframe id="ifrmStatus" class="displayNone" src="<%= _247URL%>/Marketing/LoginStatus.aspx?op=status&domain=<%= _domain%>" />
    <iframe id="ifmBackEnd" class="displayNone" src="<%= _247URL%>/Marketing/GetFrameUrl.aspx?FrameUrl=<%= Server.UrlEncode(Request.Url.ToString())%>" />
</body>
</html>
